# ===== NextAuth =====
NEXTAUTH_URL=https://your-vercel-url.vercel.app
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# ===== Built-in admin password =====
# Default: Admin1234! (change this in production)
ADMIN_PASSWORD=ChangeMeInProduction!

# ===== Google OAuth (optional — for "Sign in with Google" button) =====
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== Supabase (optional — for persistent users / settings) =====
# Without these, the app falls back to in-memory storage that resets
# on Vercel cold starts. See supabase/SETUP.md for setup steps.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJ...
